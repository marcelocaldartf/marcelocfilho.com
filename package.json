{
  "name": "marcelocfilho-com",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync": "git submodule update --init --recursive && git -C .rimelight-utilities fetch origin && git -C .rimelight-utilities checkout main && git -C .rimelight-utilities pull origin main && bun ./.rimelight-utilities/scripts/sync.ts && husky && nuxt prepare",
    "build": "nuxt build",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "i18n": "vue-i18n-extract report --vueFiles './{app,server,shared}/**/*.?(js|vue|ts)' --languageFiles './i18n/locales/*.?(json|yml|yaml|js)' --exclude 'studio.tooltips.toggleStudio'",
    "i18n:add": "vue-i18n-extract report --vueFiles './{app,server,shared}/**/*.?(js|vue|ts)' --languageFiles './i18n/locales/*.?(json|yml|yaml|js)' --add --exclude 'studio.tooltips.toggleStudio'",
    "i18n:remove": "vue-i18n-extract report --vueFiles './{app,server,shared}/**/*.?(js|vue|ts)' --languageFiles './i18n/locales/*.?(json|yml|yaml|js)' --remove --exclude 'studio.tooltips.toggleStudio'",
    "i18n:fix": "vue-i18n-extract report --vueFiles './{app,server,shared}/**/*.?(js|vue|ts)' --languageFiles './i18n/locales/*.?(json|yml|yaml|js)' --add --remove --exclude 'studio.tooltips.toggleStudio'",
    "typecheck": "nuxt prepare && vue-tsc --noEmit && nuxt typecheck",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt .",
    "check": "bun run i18n && bun run typecheck && bun run lint && bun run format",
    "fix": "bun run i18n:fix && bun run lint:fix && bun run format:fix"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.90",
    "@iconify-json/simple-icons": "^1.2.70",
    "@nuxt/content": "^3.11.2",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "^0.13.2",
    "@nuxt/ui": "^4.5.0",
    "@nuxtjs/i18n": "^10.2.3",
    "@nuxtjs/robots": "^5.7.0",
    "@nuxtjs/sitemap": "^7.6.0",
    "@vueuse/nuxt": "^14.2.1",
    "better-sqlite3": "^12.6.2",
    "date-fns": "^4.1.0",
    "nuxt": "^4.3.1",
    "nuxt-llms": "^0.2.0",
    "nuxt-og-image": "^5.1.13",
    "nuxt-studio": "^1.4.0",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.1",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@nuxt/a11y": "^1.0.0-alpha.1",
    "@nuxt/devtools": "^3.2.2",
    "@nuxt/schema": "^4.3.1",
    "@nuxt/test-utils": "^3.23.0",
    "drizzle-kit": "^0.31.9",
    "husky": "^9.1.7",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vue-i18n-extract": "^2.0.7",
    "vue-tsc": "^3.2.5",
    "wrangler": "^4.68.1"
  }
}
