{
  "name": "marcelocfilho.com",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync": "bunx rimelight sync && husky && nuxt prepare",
    "sync:agents": "bunx rimelight sync --agents",
    "sync:configs": "bunx rimelight sync --configs",
    "analyze": "nuxi analyze",
    "build": "nuxt build",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "i18n": "vue-i18n-extract report --vueFiles \"./{app,server,shared,auth,types}/**/*.?(js|vue|ts)\" --languageFiles \"./i18n/locales/*.?(json|yml|yaml|js)\"",
    "i18n:add": "vue-i18n-extract report --vueFiles \"./{app,server,shared,auth,types}/**/*.?(js|vue|ts)\" --languageFiles \"./i18n/locales/*.?(json|yml|yaml|js)\" --add",
    "i18n:remove": "vue-i18n-extract report --vueFiles \"./{app,server,shared,auth,types}/**/*.?(js|vue|ts)\" --languageFiles \"./i18n/locales/*.?(json|yml|yaml|js)\" --remove",
    "i18n:fix": "vue-i18n-extract report --vueFiles \"./{app,server,shared,auth,types}/**/*.?(js|vue|ts)\" --languageFiles \"./i18n/locales/*.?(json|yml|yaml|js)\" --add --remove",
    "typecheck": "nuxt prepare && vue-tsc --noEmit && nuxt typecheck",
    "lint": "oxlint -c ./oxlint.config.ts .",
    "lint:fix": "oxlint -c ./oxlint.config.ts . --fix",
    "format": "oxfmt -c ./.oxfmtrc.jsonc --check",
    "format:fix": "oxfmt -c ./.oxfmtrc.jsonc .",
    "check": "bun run i18n && bun run typecheck && bun run lint && bun run format",
    "fix": "bun run i18n:fix && bun run lint:fix && bun run format:fix",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:unit": "vitest --project unit",
    "test:nuxt": "vitest --project nuxt",
    "test:e2e": "vitest --project e2e"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.90",
    "@iconify-json/simple-icons": "^1.2.70",
    "@nuxt/content": "^3.12.0",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "^0.13.2",
    "@nuxt/ui": "^4.5.1",
    "@nuxtjs/device": "^4.0.0",
    "@nuxtjs/i18n": "^10.2.3",
    "@nuxtjs/seo": "^3.4.0",
    "better-sqlite3": "^12.6.2",
    "nuxt": "^4.4.2",
    "nuxt-llms": "^0.2.0",
    "nuxt-og-image": "^5.1.13",
    "nuxt-security": "^2.5.1",
    "nuxt-studio": "^1.4.0",
    "tailwindcss": "^4.2.1",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@nuxt/a11y": "^1.0.0-alpha.1",
    "@nuxt/devtools": "^3.2.2",
    "@nuxt/hints": "^1.0.0",
    "@nuxt/schema": "^4.3.1",
    "@nuxt/test-utils": "^4.0.0",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "husky": "^9.1.7",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.50.0",
    "rimelight-cli": "github:Rimelight-Entertainment/rimelight-cli",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vue-i18n-extract": "^2.0.7",
    "vue-tsc": "^3.2.5",
    "wrangler": "^4.68.1"
  }
}
